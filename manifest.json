{
  "manifest_version": 3,
  "name": "ChatGPT Workspace Exporter",
  "description": "Export your ChatGPT conversations and projects from the signed-in web app.",
  "version": "0.1.0",
  "action": {
    "default_title": "ChatGPT Exporter",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "permissions": [
    "activeTab",
    "downloads"
  ]
}
